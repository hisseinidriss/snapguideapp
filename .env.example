# Frontend env (used by Vite at build time).
# Leave empty when deploying to Azure Static Web Apps with a linked Function App
# (requests will be proxied to /api/* automatically).
# Set this when running locally against a remote backend, e.g.:
#   VITE_API_BASE_URL=https://snapguide-api.azurewebsites.net
VITE_API_BASE_URL=
