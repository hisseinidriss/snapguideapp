# Frontend env (used by Vite at build time).
#
# All API calls go to the absolute Azure Function App URL. The frontend never
# uses relative /api paths against the Static Web App origin (that would
# return 405). Leave this blank to use the built-in default backend:
#
#   https://snapeguide1-hjakarahbzhcc2dk.uaenorth-01.azurewebsites.net
#
# Override only when running against a different backend, e.g. local Functions:
#   VITE_API_BASE_URL=http://localhost:7071
# Or another deployed Function App:
#   VITE_API_BASE_URL=https://my-other-functionapp.azurewebsites.net
#
# Rules (enforced by vite.config.ts at build time):
#   - Must start with http:// or https://
#   - Must NOT contain /api  (the client appends it automatically)
#   - Must NOT end with a trailing slash
VITE_API_BASE_URL=
